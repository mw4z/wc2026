// FIFA World Cup 2026 — Prediction Game
// All timestamps are stored in UTC (Postgres `timestamptz`). Display localization
// happens in the UI layer only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum Stage {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

enum MatchStatus {
  SCHEDULED // open for prediction (until kickoffAt)
  LOCKED // kickoff reached, predictions frozen
  LIVE
  FINISHED // 90'/ET done, score known, not yet scored
  SCORED // points awarded to predictions
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SCORE
  RECALCULATE
}

enum GroupRole {
  LEADER
  MEMBER
}

// ----------------------------------------------------------------------------
// Core models
// ----------------------------------------------------------------------------

model User {
  id         String   @id @default(cuid())
  // LEGACY identity (pre-phone login). Kept nullable for backward compatibility
  // with existing accounts (e.g. admin "1001"). New users use phoneE164.
  employeeId String?  @unique
  // Phone login identity, stored in E.164 (e.g. +966551234567). Never shown publicly.
  phoneE164  String?  @unique
  name       String
  department String?
  email      String?  @unique
  role       Role     @default(USER)
  // Admin can deactivate suspicious users; inactive users cannot log in or predict.
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  predictions        Prediction[]
  predictionAuditLog PredictionAuditLog[]
  matchResultAudits  MatchResultAuditLog[] @relation("AdminAudits")
  ledGroups          Group[]               @relation("GroupLeader")
  groupMemberships   GroupMember[]
  pushSubscriptions  PushSubscription[]

  @@index([role])
  @@index([isActive])
}

// Simple key/value app config. Known keys:
//   "registration_open" = "true" | "false"  — when false, no new users are
//   created at login (admins close it once the tournament starts).
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Team {
  id        String   @id @default(cuid())
  code      String   @unique // FIFA 3-letter code, or "TBD" placeholder
  nameEn    String
  nameAr    String
  flagUrl   String?
  groupName String? // "A".."L" for group stage teams
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homeMatches   Match[] @relation("HomeTeam")
  awayMatches   Match[] @relation("AwayTeam")
  wonMatches    Match[] @relation("WinnerTeam")
  predictedWins Prediction[] @relation("PredictedWinner")

  @@index([groupName])
}

model Match {
  id          String      @id @default(cuid())
  matchNumber Int         @unique
  stage       Stage
  homeTeamId  String?
  awayTeamId  String?
  kickoffAt   DateTime // UTC
  city        String?
  stadium     String?
  status      MatchStatus @default(SCHEDULED)

  // Result (filled by admin). homeScore/awayScore = result BEFORE penalties.
  homeScore        Int?
  awayScore        Int?
  wentToPenalties  Boolean   @default(false)
  // For knockout matches: the team that advanced (may differ from score winner on penalties).
  winnerTeamId     String?
  resultConfirmedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homeTeam   Team? @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team? @relation("AwayTeam", fields: [awayTeamId], references: [id])
  winnerTeam Team? @relation("WinnerTeam", fields: [winnerTeamId], references: [id])

  predictions Prediction[]
  resultAudit MatchResultAuditLog[]
  groupRules  GroupMatchRule[]

  @@index([status])
  @@index([kickoffAt])
  @@index([stage])
}

model Prediction {
  id                   String  @id @default(cuid())
  userId               String
  matchId              String
  predictedHomeScore   Int
  predictedAwayScore   Int
  // Knockout only: which team the user thinks advances.
  predictedWinnerTeamId String?

  // Scoring results (null until match is SCORED).
  pointsAwarded      Int?
  isExactScore       Boolean @default(false)
  isCorrectOutcome   Boolean @default(false)
  isCorrectQualifier Boolean @default(false)

  submittedAt DateTime @default(now()) // first creation time (used for tie-breaks)
  updatedAt   DateTime @updatedAt

  user            User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match           Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  predictedWinner Team? @relation("PredictedWinner", fields: [predictedWinnerTeamId], references: [id])

  // One prediction per user per match — the core anti-cheat constraint.
  @@unique([userId, matchId])
  @@index([matchId])
}

// ----------------------------------------------------------------------------
// Audit logs
// ----------------------------------------------------------------------------

model PredictionAuditLog {
  id           String      @id @default(cuid())
  predictionId String?
  userId       String
  matchId      String
  action       AuditAction
  oldValue     Json?
  newValue     Json?
  createdAt    DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([userId])
}

model MatchResultAuditLog {
  id          String      @id @default(cuid())
  matchId     String
  adminUserId String
  action      AuditAction
  oldValue    Json?
  newValue    Json?
  createdAt   DateTime    @default(now())

  match     Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  adminUser User  @relation("AdminAudits", fields: [adminUserId], references: [id])

  @@index([matchId])
}

// ----------------------------------------------------------------------------
// Leaderboard snapshot (denormalized, rebuilt by recalculateLeaderboard()).
// One row per user. Querying this is O(rows) and avoids recomputing on read.
// ----------------------------------------------------------------------------

model LeaderboardEntry {
  id                 String   @id @default(cuid())
  userId             String   @unique
  name               String
  department         String?
  totalPoints        Int      @default(0)
  exactScores        Int      @default(0)
  correctOutcomes    Int      @default(0)
  correctQualifiers  Int      @default(0)
  totalPredictions   Int      @default(0)
  scoredPredictions  Int      @default(0)
  accuracy           Float    @default(0) // exactScores / scoredPredictions
  lastPredictionAt   DateTime? // tie-break #4
  rank               Int      @default(0)
  updatedAt          DateTime @updatedAt

  @@index([rank])
  @@index([totalPoints])
}

// ----------------------------------------------------------------------------
// Groups (Phase D). Predictions stay GLOBAL; a group leaderboard is just the
// global LeaderboardEntry filtered to the group's members.
// ----------------------------------------------------------------------------

model Group {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique // normalized "CUP-XXXXX"
  leaderId  String
  isActive  Boolean  @default(true)

  // Per-group scoring (leader-customizable). These are the group-wide defaults
  // applied to every match; GroupMatchRule overrides specific matches. The
  // GLOBAL leaderboard always uses the standard 3/1/+1 — these only affect this
  // group's own leaderboard, computed live from the stored correctness flags.
  pointsExact     Int     @default(3)
  pointsOutcome   Int     @default(1)
  pointsQualifier Int     @default(1)
  // Winner-only mode: ignore the exact-score bonus — a correct result earns
  // pointsOutcome whether or not the exact score matched.
  winnerOnly      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leader     User             @relation("GroupLeader", fields: [leaderId], references: [id])
  members    GroupMember[]
  matchRules GroupMatchRule[]

  @@index([code])
  @@index([isActive])
}

// Per-match point overrides for a single group. A row exists only when the
// leader customized that match; null fields fall back to the group default.
model GroupMatchRule {
  id              String   @id @default(cuid())
  groupId         String
  matchId         String
  pointsExact     Int?
  pointsOutcome   Int?
  pointsQualifier Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([groupId, matchId])
  @@index([groupId])
}

// ----------------------------------------------------------------------------
// Web Push (Phase: reminders). A browser PushSubscription per device/user.
// A small hourly cron sends "your predictions close soon" notifications.
// No phone numbers, no third-party messaging — standard Web Push (VAPID).
// ----------------------------------------------------------------------------

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique // the push service URL (unique per device subscription)
  p256dh    String // client public key (for payload encryption)
  auth      String // client auth secret
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Dedupe log: at most one reminder per (user, match) so the hourly cron never
// spams. A row means "we already nudged this user about this match".
model PushReminder {
  id      String   @id @default(cuid())
  userId  String
  matchId String
  kind    String   @default("closing") // "open" | "closing" | "scored"
  sentAt  DateTime @default(now())

  @@unique([userId, matchId, kind])
  @@index([sentAt])
}

model GroupMember {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId])
}
