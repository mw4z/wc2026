# --- Database (Neon Postgres) ---
# Pooled connection (used by the app at runtime). Neon gives you a "-pooler" host.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/wc2026?sslmode=require"
# Direct connection (used by Prisma Migrate only). Non-pooled host.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/wc2026?sslmode=require"

# --- Auth ---
# 32+ char random secret used to sign session JWTs. Generate: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string-min-32-chars"

# --- App config ---
# IANA timezone used for ADMIN display only; DB always stores UTC.
NEXT_PUBLIC_DISPLAY_TZ="Asia/Riyadh"
# Phone-based bootstrap admins (E.164), comma-separated. These phones get ADMIN on login.
ADMIN_PHONE_NUMBERS="+966500000000"
# LEGACY (pre-phone login) bootstrap admins by employeeId — kept for transition only.
ADMIN_EMPLOYEE_IDS="1001,302254"

# --- Ads (Google AdSense) --- DISABLED by default. See docs/ADSENSE.md.
# Ads render ONLY when this is exactly "true" AND a client id is set.
NEXT_PUBLIC_ENABLE_ADS="false"
# AdSense client id = "ca-pub-" + publisher number. Publisher: pub-7307749688711791
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-7307749688711791"
NEXT_PUBLIC_ADSENSE_MATCHES_TOP_SLOT=""
NEXT_PUBLIC_ADSENSE_LEADERBOARD_TOP_SLOT=""
NEXT_PUBLIC_ADSENSE_GROUP_TOP_SLOT=""
NEXT_PUBLIC_ADSENSE_RULES_BOTTOM_SLOT=""
NEXT_PUBLIC_ADSENSE_FAQ_BOTTOM_SLOT=""
# Public support email shown on /contact and /privacy.
NEXT_PUBLIC_CONTACT_EMAIL="support@example.com"
